{
  "mcpServers": {
    "puppeteer": {
      "description": "Headless Chrome browser automation.",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"]
    },
    "remote-http": {
      "description": "Connect to an MCP server already running over Streamable HTTP.",
      "type": "http",
      "url": "http://127.0.0.1:13337/mcp"
    },
    "adb": {
      "description": "Adb MCP.",
      "command": "python",
      "args": ["C:/mcp/adb/server.py"]
    },
    "ida": {
      "description": "IDA MCP",
      "type": "http",
      "url": "http://127.0.0.1:13337/mcp"
    }
  }
}
